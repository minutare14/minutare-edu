{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && tsx server.ts",
    "build": "npm run generate:exams && vite build",
    "generate:exams": "tsx lib/exams/generateImportedExams.ts",
    "start": "tsx server.ts",
