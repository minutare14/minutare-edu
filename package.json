    "cookie": "^1.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "katex": "^0.16.44",
    "lucide-react": "^0.546.0",
    "marked": "^17.0.5",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "pg-mem": "^3.0.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
