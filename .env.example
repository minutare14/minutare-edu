NODE_ENV=production

# Host port chosen after auditing the VPS.
APP_PORT=3010

# Internal application port inside the container.
PORT=3000

# Public URL used by the app in production. Required.
APP_URL=http://SEU_DOMINIO_OU_IP:3010

# Gemini provider. Optional only if you accept the IA in fallback mode.
GEMINI_API_KEY=coloque_sua_chave_gemini

# Private auth bootstrap for the only two allowed users. Required.
APP_OWNER_EMAIL=owner@example.com
APP_OWNER_PASSWORD=troque-esta-senha-owner
APP_MEMBER_EMAIL=member@example.com
APP_MEMBER_PASSWORD=troque-esta-senha-member

# Session hardening. Required.
SESSION_SECRET=gere-um-segredo-longo-e-aleatorio

# PostgreSQL used by the Docker Compose stack. Required.
POSTGRES_DB=ctia03
POSTGRES_USER=ctia03
POSTGRES_PASSWORD=troque-esta-senha-do-postgres
DATABASE_SSL=false
DATABASE_URL=postgresql://ctia03:troque-esta-senha-do-postgres@db:5432/ctia03
